# Copy to .env and fill in. Used by controller.py / controller_demo.py.

# --- Backend (base URL, NOT the old /readings path) ---
BACKEND_URL=http://192.168.4.10:4000
INGEST_API_KEY=change-me-to-match-the-backend   # must equal the backend's INGEST_API_KEY
HTTP_TIMEOUT=5

DEVICE_ID=pi-01
FW_VERSION=0.5.0-staging

# --- Loop timing ---
SEND_INTERVAL=30
BACKFILL_BATCH=50

# --- ADC / sensors ---
# 3.3 = MCP3008 VDD/VREF wired to the Pi's 3.3V rail (our wiring). Use 5.0 only
# if you rewire VREF to a 5V source. This MUST match the physical rail: get it wrong
# and every NH3 threshold is off by a 1.5x factor, so the exchange never triggers.
VREF=3.3
SAMPLES_PER_READ=10
NH3_CHANNEL=2
PH_CHANNEL=0
PH_NEUTRAL_VOLTAGE=2.549
PH_SLOPE=3.5

# --- Water level (JSN-SR04T) ---
LEVEL_TRIG_PIN=23
LEVEL_ECHO_PIN=24
LEVEL_MAX_DISTANCE_CM=100
LEVEL_SAMPLES=5
LEVEL_QUEUE_LEN=9
LEVEL_SAMPLE_GAP_S=0.06

# --- Relay / actuators (BCM pins — matches the wired relay: IN1=17, IN2=27) ---
PUMP_PIN=17
VALVE_PIN=27
# Most cheap relay boards are ACTIVE-LOW (GPIO low = relay energised = load ON).
# Only true/false/1/0/yes/no/on/off are accepted — an unrecognised value is a hard
# error, NOT a silent false, because guessing wrong here inverts the relay polarity:
# the pump would run continuously while the dashboard reported it off.
RELAY_ACTIVE_LOW=true
DEFAULT_MAX_RUNTIME_SEC=120

# --- Offline buffer ---
# Relative paths resolve against the repo directory (not the process CWD), so running
# from cron or systemd can't silently open a different, empty database.
BUFFER_DB=buffer.db
BUFFER_KEEP_SYNCED=5000
BUFFER_MAX_PENDING=50000
